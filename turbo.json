{
  "globalDependencies": ["**/.env.example"],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "ANTHROPIC_API_KEY",
    "DEEPSEEK_API_KEY",
    "GEMINI_API_KEY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "NEWS_API_KEY",
    "GNEWS_API_KEY",
    "MEDIASTACK_API_KEY",
    "CURRENTS_API_KEY",
    "GUARDIAN_API_KEY",
    "NYT_API_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "CRON_SECRET",
    "USE_AI_CLASSIFIER",
    "AI_CLASSIFIER_SHADOW_MODE"
  ],
  "tasks": {
    "dev": {
      "cache": false
    },
    "build": {
      "outputs": [".next/**", "dist/**"],
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    }
  }
}
