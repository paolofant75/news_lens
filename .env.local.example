# ─── Lens Veritas — esempio .env.local ──────────────────────────────────────
# Copia questo file in `.env.local` (root) e/o `apps/web/.env.local`, poi
# sostituisci i valori. Le chiavi presenti qui rispecchiano la convention
# attuale del progetto (vedi anche .env.example per le altre variabili).
# ────────────────────────────────────────────────────────────────────────────

# AI Category Classifier
# Quando "true", il world-filter usa la classificazione AI (Claude).
# Quando "false" o assente, usa la logica legacy keyword/regex.
# Per rollback istantaneo in produzione: setta a "false" su Vercel.
USE_AI_CLASSIFIER=false

# Shadow mode: il cron classify-articles popola i campi aiCategory/aiWorldEligible/...
# sugli articoli, ma la UI continua a usare Legacy. Serve per confrontare A/B
# via /api/admin/classifier-diff prima di flippare USE_AI_CLASSIFIER=true.
# Attivo SOLO quando AI_CLASSIFIER_SHADOW_MODE=true E USE_AI_CLASSIFIER=false.
AI_CLASSIFIER_SHADOW_MODE=false
