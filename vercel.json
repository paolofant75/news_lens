{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "app/api/cron/refresh-feeds/route.ts": { "maxDuration": 60 },
    "app/api/cron/classify-articles/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-feeds",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/classify-articles",
      "schedule": "*/30 * * * *"
    }
  ]
}
